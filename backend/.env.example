# Banco de dados (Neon PostgreSQL) — connection string oficial
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-1.aws.neon.tech/dbname?sslmode=require

# Origens permitidas no CORS (frontend)
CORS_ORIGINS=http://localhost:3000,https://seu-front.vercel.app

# Chave da API-Football usada pelos coletores ETL (o código lê APIFOOTBALL_KEY)
APIFOOTBALL_KEY=your_api_football_key
